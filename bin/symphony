#!/usr/bin/env bash
# Symphony CLI wrapper — run from any project directory.
# Usage: symphony start|on|stop|off|status
set -euo pipefail

SYMPHONY_BIN="/Users/javis/Documents/workspace/projects/symphony/elixir/bin/symphony"
GUARDRAIL_FLAG="--i-understand-that-this-will-be-running-without-the-usual-guardrails"
PIDFILE="/tmp/symphony-$(echo "$PWD" | md5 -q).pid"

setup_env() {
  export LINEAR_API_KEY
  LINEAR_API_KEY="$(security find-generic-password -a "$USER" -s LINEAR_API_KEY -w)"
  export HOME="/Users/javis"
  export MIX_HOME="/Users/javis/.local/share/mise/installs/elixir/1.19.5-otp-28/.mix"
  export MIX_ARCHIVES="${MIX_HOME}/archives"
  export PATH="/Users/javis/.local/share/mise/installs/erlang/28.4.1/bin:/Users/javis/.local/share/mise/installs/elixir/1.19.5-otp-28/bin:${MIX_HOME}/escripts:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
}

case "${1:-start}" in
  start|on)
    if [ ! -f WORKFLOW.md ]; then
      echo "No WORKFLOW.md in current directory: $PWD" >&2
      exit 1
    fi
    # Guard: prevent multiple instances for the same project directory
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "Symphony already running for $PWD (pid $(cat "$PIDFILE"))" >&2
      echo "Use 'symphony stop' first, or 'symphony status' to check." >&2
      exit 1
    fi
    setup_env
    echo "Symphony starting in: $PWD"
    # Write PID file (exec replaces this process, so write the upcoming PID)
    echo $$ > "$PIDFILE"
    exec "$SYMPHONY_BIN" "$GUARDRAIL_FLAG"
    ;;
  stop|off)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      kill "$(cat "$PIDFILE")"
      rm -f "$PIDFILE"
      echo "Symphony stopped"
    else
      echo "No running Symphony found for $PWD"
    fi
    ;;
  status)
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "Running (pid $(cat "$PIDFILE"))"
    else
      echo "Not running"
    fi
    ;;
  *)
    echo "Usage: symphony [start|on|stop|off|status]" >&2
    exit 1
    ;;
esac
