#!/usr/bin/env bash
# Symphony CLI — single entry point for all project directories.
#
# Usage:
#   symphony on                 # start in current directory (requires WORKFLOW.md)
#   symphony on spanory         # start for named project
#   symphony stop               # stop instance for current directory
#   symphony stop spanory       # stop instance for named project
#   symphony status [project]   # check if running
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")/.." && pwd)"
SYMPHONY_BIN="${SCRIPT_DIR}/elixir/bin/symphony"
GUARDRAIL_FLAG="--i-understand-that-this-will-be-running-without-the-usual-guardrails"
PROJECTS_ROOT="/Users/javis/Documents/workspace/projects"

# ── Environment ──────────────────────────────────────────────────────────────
setup_env() {
  export LINEAR_API_KEY
  LINEAR_API_KEY="$(security find-generic-password -a "$USER" -s LINEAR_API_KEY -w)"
  export HOME="/Users/javis"
  export MIX_HOME="/Users/javis/.local/share/mise/installs/elixir/1.19.5-otp-28/.mix"
  export MIX_ARCHIVES="${MIX_HOME}/archives"
  export PATH="/Users/javis/.local/share/mise/installs/erlang/28.4.1/bin:/Users/javis/.local/share/mise/installs/elixir/1.19.5-otp-28/bin:${MIX_HOME}/escripts:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
}

# ── Resolve project directory ────────────────────────────────────────────────
resolve_project_dir() {
  local project="${1:-}"

  if [ -z "$project" ]; then
    # No argument — use current directory
    echo "$PWD"
    return
  fi

  # Try exact path, then common locations
  if [ -d "$project" ]; then
    echo "$(cd "$project" && pwd)"
  elif [ -d "$PROJECTS_ROOT/$project" ]; then
    echo "$PROJECTS_ROOT/$project"
  elif [ -d "$PROJECTS_ROOT/${project}-all/$project" ]; then
    echo "$PROJECTS_ROOT/${project}-all/$project"
  else
    echo "Project not found: $project" >&2
    echo "Searched: $project, $PROJECTS_ROOT/$project, $PROJECTS_ROOT/${project}-all/$project" >&2
    exit 1
  fi
}

# ── Find WORKFLOW.md in project directory ────────────────────────────────────
find_workflow() {
  local dir="$1"
  # Direct match first, then one level deep
  if [ -f "$dir/WORKFLOW.md" ]; then
    echo "$dir/WORKFLOW.md"
  else
    for candidate in "$dir"/*/WORKFLOW.md; do
      if [ -f "$candidate" ]; then
        echo "$candidate"
        return
      fi
    done
    echo "No WORKFLOW.md found in $dir or its immediate subdirectories" >&2
    exit 1
  fi
}

# ── PID file path (deterministic per project directory) ──────────────────────
pidfile_for() {
  echo "/tmp/symphony-$(echo "$1" | md5 -q).pid"
}

# ── Commands ─────────────────────────────────────────────────────────────────
ACTION="${1:-start}"
PROJECT_ARG="${2:-}"

case "$ACTION" in
  start|on)
    PROJECT_DIR="$(resolve_project_dir "$PROJECT_ARG")"
    PIDFILE="$(pidfile_for "$PROJECT_DIR")"

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "Symphony already running for $PROJECT_DIR (pid $(cat "$PIDFILE"))" >&2
      echo "Use 'symphony stop${PROJECT_ARG:+ $PROJECT_ARG}' first." >&2
      exit 1
    fi

    WORKFLOW_PATH="$(find_workflow "$PROJECT_DIR")"
    setup_env
    echo "Symphony starting in: $PROJECT_DIR"
    echo "Workflow: $WORKFLOW_PATH"
    cd "$PROJECT_DIR"
    echo $$ > "$PIDFILE"
    exec "$SYMPHONY_BIN" "on" "$WORKFLOW_PATH"
    ;;

  stop|off)
    PROJECT_DIR="$(resolve_project_dir "$PROJECT_ARG")"
    PIDFILE="$(pidfile_for "$PROJECT_DIR")"

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      kill "$(cat "$PIDFILE")"
      rm -f "$PIDFILE"
      echo "Symphony stopped for $PROJECT_DIR"
    else
      echo "No running Symphony found for $PROJECT_DIR"
    fi
    ;;

  status)
    PROJECT_DIR="$(resolve_project_dir "$PROJECT_ARG")"
    PIDFILE="$(pidfile_for "$PROJECT_DIR")"

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
      echo "Running for $PROJECT_DIR (pid $(cat "$PIDFILE"))"
    else
      echo "Not running for $PROJECT_DIR"
    fi
    ;;

  *)
    echo "Usage: symphony [on|off|status] [project-name]" >&2
    exit 1
    ;;
esac
